# Copy to .env and set your key. Never commit .env.
#
# One GOOGLE_MAPS_API_KEY for everything: Maps JS, Directions, and Weather (via api/weather.js on Vercel).
#
# Required in Google Cloud (same project as the key):
#   - Maps JavaScript API
#   - Directions API (Legacy) — enable at:
#     https://console.cloud.google.com/apis/library/directions-backend.googleapis.com
#   - Weather API (current conditions + daily forecast) — enable at:
#     https://console.cloud.google.com/apis/library/weather.googleapis.com
#   - Billing on
#
# Key restriction: HTTP referrers — include http://127.0.0.1:*/* http://localhost:*/*
# and your production URL(s), e.g. https://*.vercel.app/*

GOOGLE_MAPS_API_KEY=
